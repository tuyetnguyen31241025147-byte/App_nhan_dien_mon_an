import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader, random_split
from torchvision import datasets, transforms, models
import matplotlib.pyplot as plt
import numpy as np
import os
import json
from sklearn.metrics import classification_report

# Kiểm tra GPU
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Đang dùng: {device}")
# Nên thấy: Đang dùng: cuda

# Transform = các bước xử lý ảnh trước khi đưa vào model

# Transform cho tập TRAIN (có augmentation để tăng độ đa dạng)
train_transform = transforms.Compose([
    transforms.Resize((256, 256)),
    transforms.RandomCrop(224),
    transforms.RandomHorizontalFlip(),
    transforms.RandomVerticalFlip(),
    transforms.RandomRotation(30),
    transforms.ColorJitter(
        brightness=0.4,
        contrast=0.4,
        saturation=0.3,
        hue=0.1
    ),
    transforms.ToTensor(),
    transforms.Normalize(
        mean=[0.485, 0.456, 0.406],
        std=[0.229, 0.224, 0.225]
    )
])

DATASET_PATH = "/content/drive/MyDrive/Canteen_Project/dataset_mon_an"

# Load toàn bộ dataset
full_dataset = datasets.ImageFolder(
    root=DATASET_PATH,
    transform=train_transform
)

# In thông tin
print(f"Tổng số ảnh   : {len(full_dataset)}")
print(f"Số loại món   : {len(full_dataset.classes)}")
print(f"Danh sách món : {full_dataset.classes}")

# Lưu mapping tên món để dùng sau
class_to_idx = full_dataset.class_to_idx
idx_to_class = {v: k for k, v in class_to_idx.items()}
print(f"\nMapping index → tên món:")
for idx, name in idx_to_class.items():
    print(f"  {idx}: {name}")

# Chia 80% train, 20% validation
total = len(full_dataset)
train_size = int(0.8 * total)
val_size = total - train_size

train_dataset, val_dataset = random_split(
    full_dataset,
    [train_size, val_size],
    generator=torch.Generator().manual_seed(42)  # Để kết quả ổn định
)

# Gán transform riêng cho val
val_dataset.dataset.transform = val_transform

# Tạo DataLoader
train_loader = DataLoader(
    train_dataset,
    batch_size=32,      # Xử lý 32 ảnh mỗi lần
    shuffle=True,       # Trộn ngẫu nhiên
    num_workers=2
)

val_loader = DataLoader(
    val_dataset,
    batch_size=32,
    shuffle=False,
    num_workers=2
)

print(f"Train: {train_size} ảnh | Val: {val_size} ảnh")

def build_resnet50(num_classes):
    model = models.resnet50(weights=models.ResNet50_Weights.IMAGENET1K_V1)

    for name, param in model.named_parameters():
        if "layer4" in name or "fc" in name:
            param.requires_grad = True
        else:
            param.requires_grad = False

    num_features = model.fc.in_features
    model.fc = nn.Sequential(
        nn.Dropout(0.5),
        nn.Linear(num_features, 256),
        nn.ReLU(),
        nn.Dropout(0.3),
        nn.Linear(256, num_classes)
    )
    return model

NUM_CLASSES = len(full_dataset.classes)
model = build_resnet50(NUM_CLASSES)
model = model.to(device)

print(f"✅ Model ResNet50 sẵn sàng")
print(f"   Số loại món cần nhận diện: {NUM_CLASSES}")

# Loss function: CrossEntropy cho bài toán phân loại nhiều lớp
class_weights = torch.ones(NUM_CLASSES)
for i, name in enumerate(full_dataset.classes):
    if "Sườn" in name:
        class_weights[i] = 2.5
    elif "Thịt kho" in name and "trứng" not in name.lower():
        class_weights[i] = 2.5
    elif "Đậu hũ" in name:
        class_weights[i] = 2.0
    elif "Cá hú" in name:
        class_weights[i] = 2.0

class_weights = class_weights.to(device)
criterion = nn.CrossEntropyLoss(weight=class_weights)
print("✅ Class weights:", class_weights)

# Optimizer: Chỉ train các parameter của layer fc (layer cuối)
# Unfreeze layer4 nên cần learning rate nhỏ hơn cho layer4
optimizer = optim.Adam([
    {"params": model.fc.parameters(),    "lr": 0.001},
    {"params": model.layer4.parameters(), "lr": 0.0001},
])
# Scheduler: Giảm learning rate nếu val_loss không cải thiện
scheduler = optim.lr_scheduler.ReduceLROnPlateau(
    optimizer,
    mode='min',
    patience=3,    # Chờ 3 epoch không cải thiện mới giảm lr
    factor=0.5     # Giảm lr xuống còn 50%
)

def train_one_epoch(model, loader, criterion, optimizer):
    model.train()
    total_loss, total_correct, total_samples = 0, 0, 0

    for batch_idx, (images, labels) in enumerate(loader):
        images, labels = images.to(device), labels.to(device)

        optimizer.zero_grad()           # Reset gradient
        outputs = model(images)         # Forward pass
        loss = criterion(outputs, labels)  # Tính loss
        loss.backward()                 # Backward pass
        optimizer.step()                # Cập nhật weights

        # Tính accuracy
        _, predicted = torch.max(outputs, 1)
        total_correct += (predicted == labels).sum().item()
        total_loss += loss.item() * images.size(0)
        total_samples += images.size(0)

    return total_loss / total_samples, total_correct / total_samples


def validate(model, loader, criterion):
    model.eval()
    total_loss, total_correct, total_samples = 0, 0, 0

    with torch.no_grad():   # Không tính gradient khi validate
        for images, labels in loader:
            images, labels = images.to(device), labels.to(device)
            outputs = model(images)
            loss = criterion(outputs, labels)

            _, predicted = torch.max(outputs, 1)
            total_correct += (predicted == labels).sum().item()
            total_loss += loss.item() * images.size(0)
            total_samples += images.size(0)

    return total_loss / total_samples, total_correct / total_samples

