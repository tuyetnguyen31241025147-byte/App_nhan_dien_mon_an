import unicodedata
import cv2
import torch
import json
import os
import numpy as np
from scipy.optimize import linear_sum_assignment
from torchvision import transforms, models
from PIL import Image
import torch.nn as nn
from flask import Flask, render_template, Response, jsonify
import threading

app = Flask(__name__)

# ── Cấu hình đường dẫn ──────────────────────────────────────
RESNET_MODEL_PATH = r"C:\canteen_project\models\resnet50_canteen.pt"
METADATA_PATH     = r"C:\canteen_project\models\metadata.json"

# ── Bảng giá ────────────────────────────────────────────────
MENU_PRICES = {
    "1. Cơm trắng"      : 10000,
    "10. Trứng chiên"   : 25000,
    "2. Đậu hũ sốt cà"  : 25000,
    "3. Cá hú kho"      : 30000,
    "4. Thịt kho trứng" : 30000,
    "5. Thịt kho"       : 25000,
    "6. Canh chua"      : 10000,
    "7. Sườn nướng"     : 30000,
    "8. Canh rau"       : 7000,
    "9. Rau xào"        : 10000,
}

# ── Load metadata ────────────────────────────────────────────
with open(METADATA_PATH, "r", encoding="utf-8") as f:
    metadata = json.load(f)

idx_to_class = {int(k): v for k, v in metadata["idx_to_class"].items()}
NUM_CLASSES  = metadata["num_classes"]
print(f"✅ Loaded {NUM_CLASSES} classes")


def _chuan_hoa(s):
    return unicodedata.normalize('NFC', s.strip())


RICE_LABEL  = "1. Cơm trắng"
SOUP_LABELS = ["6. Canh chua", "8. Canh rau"]

RICE_IDX = next(
    idx for idx, name in idx_to_class.items()
    if _chuan_hoa(name) == _chuan_hoa(RICE_LABEL)
)
SOUP_INDICES = [
    idx for idx, name in idx_to_class.items()
    if _chuan_hoa(name) in [_chuan_hoa(s) for s in SOUP_LABELS]
]
OTHER_INDICES = [
    idx for idx in idx_to_class
    if idx != RICE_IDX and idx not in SOUP_INDICES
]

idx_thit_kho = next(
    idx for idx, name in idx_to_class.items()
    if _chuan_hoa(name) == _chuan_hoa("5. Thịt kho")
)
idx_thit_kho_trung = next(
    idx for idx, name in idx_to_class.items()
    if _chuan_hoa(name) == _chuan_hoa("4. Thịt kho trứng")
)
idx_suon_nuong = next(
    idx for idx, name in idx_to_class.items()
    if _chuan_hoa(name) == _chuan_hoa("7. Sườn nướng")
)
idx_trung_chien = next(
    idx for idx, name in idx_to_class.items()
    if _chuan_hoa(name) == _chuan_hoa("10. Trứng chiên")
)

print(f"✅ RICE_IDX={RICE_IDX}, SOUP_INDICES={SOUP_INDICES}")

# ── Load ResNet50 ────────────────────────────────────────────
print("🔍 Loading ResNet50...")
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

resnet_model = models.resnet50(weights=None)
resnet_model.fc = nn.Sequential(
    nn.Dropout(0.5),
    nn.Linear(2048, 256),
    nn.ReLU(),
    nn.Dropout(0.3),
    nn.Linear(256, NUM_CLASSES)
)
resnet_model.load_state_dict(
    torch.load(RESNET_MODEL_PATH, map_location=device)
)
resnet_model = resnet_model.to(device)
resnet_model.eval()
print("✅ ResNet50 loaded!")

# ── Transform ────────────────────────────────────────────────
transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
    transforms.Normalize(
        mean=[0.485, 0.456, 0.406],
        std=[0.229, 0.224, 0.225]
    )
])

# ── Tỉ lệ cắt 5 ô ───────────────────────────────────────────
RATIOS = {
    "x_start" : 0.10,
    "x_end"   : 0.90,
    "y_start" : 0.02,
    "y_end"   : 0.98,
    "split_y" : 0.47,
}
PAD = 0.012


def crop_5_compartments(frame, ratios=RATIOS, pad=PAD):
    H, W = frame.shape[:2]
    r  = ratios
    x0 = r["x_start"]
    x1 = r["x_end"]
    y0 = r["y_start"]
    y1 = r["y_end"]
    sy = r["split_y"]
    mid = (x0 + x1) / 2
    w3  = (x1 - x0) / 3

    def cut(rx1, ry1, rx2, ry2):
        return frame[
            int(H*(ry1+pad)) : int(H*(ry2-pad)),
            int(W*(rx1+pad)) : int(W*(rx2-pad))
        ]

    return {
        "o4_com"  : cut(x0,        y0, mid,       sy),
        "o5_canh" : cut(mid,        y0, x1,        sy),
        "o1"      : cut(x0,         sy, x0+w3,     y1),
        "o2"      : cut(x0+w3,      sy, x0+w3*2,   y1),
        "o3"      : cut(x0+w3*2,    sy, x1,         y1),
    }


# ── Hàm lấy xác suất từ ResNet50 ────────────────────────────
def get_probs(crop_img):
    if crop_img.size == 0:
        return np.ones(NUM_CLASSES) / NUM_CLASSES
    img_rgb = cv2.cvtColor(crop_img, cv2.COLOR_BGR2RGB)
    img_pil = Image.fromarray(img_rgb)
    tensor  = transform(img_pil).unsqueeze(0).to(device)
    with torch.no_grad():
        outputs = resnet_model(tensor)
        probs   = torch.softmax(outputs, dim=1)[0]
    return probs.cpu().numpy()


# ── Đếm số miếng để phân biệt Sườn vs Thịt kho ─────────────
def dem_so_mieng(crop_img, min_area_ratio=0.03):
    if crop_img.size == 0:
        return 1
    gray = cv2.cvtColor(crop_img, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (5, 5), 0)
    _, thresh = cv2.threshold(blur, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    total_area = crop_img.shape[0] * crop_img.shape[1]
    so_mieng = sum(1 for c in contours if cv2.contourArea(c) > total_area * min_area_ratio)
    return max(so_mieng, 1)


# ── Phân loại 5 ô ────────────────────────────────────────────
def phan_loai_5_o(crops):
    all_cells   = ["o1", "o2", "o3", "o4_com", "o5_canh"]
    big_cells   = ["o4_com", "o5_canh"]
    small_cells = ["o1", "o2", "o3"]

    # Lấy probs cho cả 5 ô
    cell_probs = {}
    for ten_o in all_cells:
        cell_probs[ten_o] = get_probs(crops[ten_o]).copy()

    # ── Bước 1: Xác định ô cơm và ô canh ────────────────────
    rice_cell = max(big_cells, key=lambda c: cell_probs[c][RICE_IDX])
    soup_cell = [c for c in big_cells if c != rice_cell][0]

    ket_qua_5_o = {
        rice_cell: (RICE_LABEL, float(cell_probs[rice_cell][RICE_IDX])),
    }

    best_soup_idx = max(SOUP_INDICES, key=lambda i: cell_probs[soup_cell][i])
    ket_qua_5_o[soup_cell] = (
        idx_to_class[best_soup_idx],
        float(cell_probs[soup_cell][best_soup_idx])
    )

    # ── Bước 2: Heuristic đếm miếng cho 3 ô nhỏ ─────────────
    for ten_o in small_cells:
        so_mieng = dem_so_mieng(crops[ten_o])
        probs    = cell_probs[ten_o]

        if so_mieng == 1:
            probs[idx_suon_nuong]    *= 3.5
            probs[idx_thit_kho]      *= 0.4
            probs[idx_thit_kho_trung]*= 0.5
        elif so_mieng == 2:
            probs[idx_thit_kho_trung]*= 3.0
            probs[idx_thit_kho]      *= 0.5
            probs[idx_suon_nuong]    *= 0.5
        elif so_mieng >= 3:
            probs[idx_thit_kho]      *= 1.5
            probs[idx_suon_nuong]    *= 0.3
            probs[idx_thit_kho_trung]*= 0.8

        # Giảm trứng chiên
        probs[idx_trung_chien] *= 0.2

        print(f"    🔍 {ten_o}: {so_mieng} miếng | "
              f"sườn={probs[idx_suon_nuong]:.3f} "
              f"thịt kho trứng={probs[idx_thit_kho_trung]:.3f} "
              f"thịt kho={probs[idx_thit_kho]:.3f}")

    # ── Bước 3: Loại bỏ 1 trong 2 (thịt kho / thịt kho trứng) ──
    max_thit_kho       = max(cell_probs[c][idx_thit_kho]       for c in small_cells)
    max_thit_kho_trung = max(cell_probs[c][idx_thit_kho_trung] for c in small_cells)
    idx_loai_bo = idx_thit_kho_trung if max_thit_kho >= max_thit_kho_trung else idx_thit_kho
    active_other = [idx for idx in OTHER_INDICES if idx != idx_loai_bo]

    # ── Bước 4: Gán 3 ô nhỏ không trùng nhau ────────────────
    prob_matrix = np.array([
        [cell_probs[c][idx] for idx in active_other]
        for c in small_cells
    ])
    row_idx, col_idx = linear_sum_assignment(-prob_matrix)

    for r, c in zip(row_idx, col_idx):
        ten_o     = small_cells[r]
        class_idx = active_other[c]
        ket_qua_5_o[ten_o] = (
            idx_to_class[class_idx],
            float(prob_matrix[r, c])
        )

    # ── Debug ─────────────────────────────────────────────────
    print("\n  📊 Top-3 mỗi ô:")
    for ten_o in all_cells:
        top3 = sorted(enumerate(cell_probs[ten_o]), key=lambda x: -x[1])[:3]
        print(f"    {ten_o}: {[(idx_to_class[i], round(p,3)) for i,p in top3]}")

    return ket_qua_5_o


# ── Hàm tính tiền ────────────────────────────────────────────
def tinh_tien(danh_sach_mon):
    hoa_don = {}
    for mon in danh_sach_mon:
        mon_chuan = _chuan_hoa(mon)
        gia = 0
        ten_chuan = mon_chuan
        for key, price in MENU_PRICES.items():
            if mon_chuan == _chuan_hoa(key):
                gia = price
                ten_chuan = key
                break
        if ten_chuan in hoa_don:
            hoa_don[ten_chuan]["so_luong"]  += 1
            hoa_don[ten_chuan]["thanh_tien"] += gia
        else:
            hoa_don[ten_chuan] = {
                "so_luong"  : 1,
                "don_gia"   : gia,
                "thanh_tien": gia
            }
    tong_tien = sum(v["thanh_tien"] for v in hoa_don.values())
    return hoa_don, tong_tien


# ── Biến toàn cục ────────────────────────────────────────────
camera        = cv2.VideoCapture(1, cv2.CAP_DSHOW)
current_frame = None
frame_lock    = threading.Lock()


def doc_camera():
    global current_frame
    while True:
        ret, frame = camera.read()
        if not ret:
            continue
        with frame_lock:
            current_frame = frame.copy()


camera_thread = threading.Thread(target=doc_camera, daemon=True)
camera_thread.start()


# ── Routes Flask ─────────────────────────────────────────────
@app.route("/")
def index():
    return render_template("index.html")


def generate_frames():
    while True:
        with frame_lock:
            if current_frame is None:
                continue
            frame = current_frame.copy()
        ret, buffer = cv2.imencode('.jpg', frame)
        if not ret:
            continue
        yield (b'--frame\r\n'
               b'Content-Type: image/jpeg\r\n\r\n' +
               buffer.tobytes() + b'\r\n')


@app.route("/video_feed")
def video_feed():
    return Response(
        generate_frames(),
        mimetype='multipart/x-mixed-replace; boundary=frame'
    )


@app.route("/nhan_dien", methods=["POST"])
def nhan_dien():
    ret, raw_frame = camera.read()
    if not ret:
        return jsonify({"hoa_don": {}, "tong_tien": 0, "so_mon": 0})

    crops       = crop_5_compartments(raw_frame)
    ket_qua_5_o = phan_loai_5_o(crops)

    danh_sach_mon = []
    for ten_o, (ten_mon, conf) in ket_qua_5_o.items():
        danh_sach_mon.append(ten_mon)
        print(f"  🍽️  {ten_o}: {ten_mon} ({conf:.1%})")

    hoa_don, tong_tien = tinh_tien(danh_sach_mon)
    print(f"  💰 Tổng tiền: {tong_tien:,}đ")

    return jsonify({
        "hoa_don"  : hoa_don,
        "tong_tien": tong_tien,
        "so_mon"   : len(danh_sach_mon)
    })


if __name__ == "__main__":
    print("\n🌐 Mở trình duyệt vào: http://127.0.0.1:5000")
    app.run(debug=False, threaded=True)
