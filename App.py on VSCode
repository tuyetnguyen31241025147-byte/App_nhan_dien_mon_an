    except Exception as e:
        return f"Lỗi tìm khay: {e}", 500
    ret, buffer = cv2.imencode('.jpg', annotated)
    return Response(buffer.tobytes(), mimetype='image/jpeg')


# ── Route: Nhận diện khi nhấn nút ───────────────────────────
@app.route("/nhan_dien", methods=["POST"])
def nhan_dien():
    global ket_qua

    ret, raw_frame = camera.read()
    if not ret:
        return jsonify({"hoa_don": {}, "tong_tien": 0, "so_mon": 0})

    try:
        corners = get_tray_corners(raw_frame)
        warped = warp_tray(raw_frame, corners)
    except Exception as e:
        print("⚠️ Không tìm thấy khay:", e)
        return jsonify({"hoa_don": {}, "tong_tien": 0, "so_mon": 0})

    crops = crop_5_compartments(warped)

    # Vì khay LUÔN có đúng 5 món không trùng nhau, và ô cơm luôn là cơm trắng
    ket_qua_5_o = phan_loai_5_o(crops)

    danh_sach_mon = []
    for ten_o, (ten_mon, conf) in ket_qua_5_o.items():
        danh_sach_mon.append(ten_mon)
        print(f"  🍽️  {ten_o}: {ten_mon} ({conf:.1%})")

    hoa_don, tong_tien = tinh_tien(danh_sach_mon)
    ket_qua = {
        "hoa_don"  : hoa_don,
        "tong_tien": tong_tien,
        "so_mon"   : len(danh_sach_mon)
    }

    print(f"  💰 Tổng tiền: {tong_tien:,}đ")
    return jsonify(ket_qua)

