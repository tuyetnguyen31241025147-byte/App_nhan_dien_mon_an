def tinh_tien(danh_sach_mon):
    hoa_don = {}
    for mon in danh_sach_mon:
        mon_chuan = unicodedata.normalize('NFC', mon.strip())
        gia = 0
        ten_chuan = mon_chuan
        for key, price in MENU_PRICES.items():
            key_chuan = unicodedata.normalize('NFC', key.strip())
            if mon_chuan == key_chuan:
                gia = price
                ten_chuan = key
                break

        if ten_chuan in hoa_don:
            hoa_don[ten_chuan]["so_luong"]  += 1
            hoa_don[ten_chuan]["thanh_tien"] += gia
        else:
            hoa_don[ten_chuan] = {
                "so_luong"  : 1,
                "don_gia"   : gia,
                "thanh_tien": gia
            }
    tong_tien = sum(v["thanh_tien"] for v in hoa_don.values())
    return hoa_don, tong_tien

