def get_tray_corners(img):
    if FIXED_CORNERS is not None:
        return FIXED_CORNERS
    return find_tray_corners_auto(img)


def warp_tray(img, corners, out_w=WARP_W, out_h=WARP_H):
    dst = np.array(
        [[0, 0], [out_w - 1, 0], [out_w - 1, out_h - 1], [0, out_h - 1]],
        dtype="float32",
    )
    M = cv2.getPerspectiveTransform(corners, dst)
    return cv2.warpPerspective(img, M, (out_w, out_h))


def crop_5_compartments(warped_img, ratios=RATIOS, pad=PAD):
    H, W = warped_img.shape[:2]
    r = ratios

    x0  = r["x_start"]
    x1  = r["x_end"]
    y0  = r["y_start"]
    y1  = r["y_end"]
    sy  = r["split_y"]
    mid = (x0 + x1) / 2
    w3  = (x1 - x0) / 3

    def cut(rx1, ry1, rx2, ry2):
        return warped_img[
            int(H*(ry1+pad)) : int(H*(ry2-pad)),
            int(W*(rx1+pad)) : int(W*(rx2-pad))
        ]

    return {
        # Hàng TRÊN: 2 ô lớn
        "o4_com"  : cut(x0,      y0, mid,  sy),   # Trái: cơm
        "o5_canh" : cut(mid,     y0, x1,   sy),   # Phải: canh

        # Hàng DƯỚI: 3 ô nhỏ đều nhau
        "o1" : cut(x0,           sy, x0+w3,    y1),
        "o2" : cut(x0+w3,        sy, x0+w3*2,  y1),
        "o3" : cut(x0+w3*2,      sy, x1,       y1),
    }

def draw_grid(warped_img, ratios=RATIOS):
    """Vẽ lưới 5 ô lên ảnh khay đã làm thẳng — dùng cho video stream xem trực quan."""
    vis = warped_img.copy()
    H, W = vis.shape[:2]
    r = ratios
    color = (80, 220, 80)
    th = 3
    cv2.line(vis, (0, int(H * r["top_h"])), (W, int(H * r["top_h"])), color, th)
    cv2.line(vis, (int(W * r["col1"]), 0), (int(W * r["col1"]), int(H * r["top_h"])), color, th)
    cv2.line(vis, (int(W * r["col2"]), 0), (int(W * r["col2"]), int(H * r["top_h"])), color, th)
    cv2.line(vis, (int(W * r["rice_w"]), int(H * r["top_h"])), (int(W * r["rice_w"]), H), color, th)
    cv2.line(vis, (int(W * r["strip_w"]), int(H * r["top_h"])), (int(W * r["strip_w"]), H), color, th)
    return vis


def find_food_box_in_cell(cell_img):
    """
    Chạy YOLO trên 1 ô nhỏ đã cắt (không phải cả khung hình) để tìm
    vị trí món ăn chính xác trong ô đó, rồi crop sát theo box đó.
    Vì vùng tìm đã giới hạn trong 1 ô, sẽ không bị ra "một đống" box
    như khi chạy YOLO trên cả khung hình to.

    Trả về ảnh đã crop sát món ăn. Nếu YOLO không tìm thấy gì
    (ô trống / conf quá thấp) -> trả về nguyên ô gốc (fallback).
    """
    if cell_img.size == 0:
        return cell_img

    results = yolo_model(cell_img, conf=YOLO_CONF_IN_CELL, imgsz=320, verbose=False)[0]

    if len(results.boxes) == 0:
        return cell_img  # không thấy món -> dùng nguyên ô (ResNet sẽ tự đánh giá conf)

    # Lấy box có confidence cao nhất trong ô
    best_box = max(results.boxes, key=lambda b: float(b.conf[0]))
    x1, y1, x2, y2 = map(int, best_box.xyxy[0].tolist())

    h, w = cell_img.shape[:2]
    x1 = max(0, x1 - YOLO_BOX_PAD)
    y1 = max(0, y1 - YOLO_BOX_PAD)
    x2 = min(w, x2 + YOLO_BOX_PAD)
    y2 = min(h, y2 + YOLO_BOX_PAD)

    crop = cell_img[y1:y2, x1:x2]
    return crop if crop.size > 0 else cell_img

def dem_so_mieng_thit(crop_img, min_area_ratio=0.03):
    """
    Đếm số 'miếng' riêng biệt trong ảnh đã crop, dựa vào contour.
    Dùng để phân biệt:
      - Sườn nướng: thường 1 (hoặc rất ít) miếng nguyên, to
      - Thịt kho  : thường nhiều miếng nhỏ rời rạc
    """
    if crop_img.size == 0:
        return 1
    gray = cv2.cvtColor(crop_img, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (5, 5), 0)
    _, thresh = cv2.threshold(blur, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    total_area = crop_img.shape[0] * crop_img.shape[1]
    so_mieng = sum(1 for c in contours if cv2.contourArea(c) > total_area * min_area_ratio)
    return max(so_mieng, 1)

