def classify_dish(crop_img):
    img_rgb = cv2.cvtColor(crop_img, cv2.COLOR_BGR2RGB)
    img_pil = Image.fromarray(img_rgb)
    tensor  = transform(img_pil).unsqueeze(0).to(device)
    with torch.no_grad():
        outputs = resnet_model(tensor)
        probs   = torch.softmax(outputs, dim=1)
        conf, pred = torch.max(probs, 1)
    return idx_to_class[pred.item()], conf.item()


def get_probs(crop_img):
    """Trả về vector xác suất CHO TẤT CẢ class (không chỉ top-1) —
    dùng để giải bài toán gán không trùng nhãn giữa các ô."""
    img_rgb = cv2.cvtColor(crop_img, cv2.COLOR_BGR2RGB)
    img_pil = Image.fromarray(img_rgb)
    tensor  = transform(img_pil).unsqueeze(0).to(device)
    with torch.no_grad():
        outputs = resnet_model(tensor)
        probs   = torch.softmax(outputs, dim=1)[0]
    return probs.cpu().numpy()


def phan_loai_5_o(crops):
    """
    Ràng buộc:
    - o4_com hoặc o5_canh → 1 ô là Cơm trắng, 1 ô là Canh (chua/rau)
    - o1, o2, o3 → 3 món khác nhau, không phải cơm/canh
    """
    all_cells = ["o1", "o2", "o3", "o4_com", "o5_canh"]
    big_cells  = ["o4_com", "o5_canh"]
    small_cells = ["o1", "o2", "o3"]

# Lấy probs cho cả 5 ô
    cell_probs = {}
    cell_crops_food = {}          # lưu lại ảnh đã crop sát món, dùng để đếm số miếng
    for ten_o in all_cells:
        food_crop = find_food_box_in_cell(crops[ten_o])
        cell_probs[ten_o] = get_probs(food_crop)
        cell_crops_food[ten_o] = food_crop

    # ── Xác định ô cơm và ô canh trong 2 ô lớn ──────────────
    # So sánh xác suất cơm giữa 2 ô lớn → ô nào cao hơn là cơm
    rice_cell  = max(big_cells, key=lambda c: cell_probs[c][RICE_IDX])
    soup_cell  = big_cells[1] if rice_cell == big_cells[0] else big_cells[0]

    ket_qua_5_o = {}

    # Ô cơm: luôn là cơm trắng
    ket_qua_5_o[rice_cell] = (RICE_LABEL, float(cell_probs[rice_cell][RICE_IDX]))

    # Ô canh: chọn giữa canh chua / canh rau (không được là cơm)
    best_soup_idx = max(SOUP_INDICES, key=lambda i: cell_probs[soup_cell][i])
    ket_qua_5_o[soup_cell] = (
        idx_to_class[best_soup_idx],
        float(cell_probs[soup_cell][best_soup_idx])
    )

    # ── Ràng buộc: Thịt kho và Thịt kho trứng không cùng xuất hiện ──
    # -> chỉ giữ loại nào có xác suất cao nhất (ở bất kỳ ô nào trong 3 ô nhỏ)
    max_thit_kho       = max(cell_probs[c][idx_thit_kho] for c in small_cells)
    max_thit_kho_trung = max(cell_probs[c][idx_thit_kho_trung] for c in small_cells)

    if max_thit_kho >= max_thit_kho_trung:
        idx_loai_bo = idx_thit_kho_trung   # bỏ "thịt kho trứng" khỏi danh sách ứng viên
    else:
        idx_loai_bo = idx_thit_kho          # bỏ "thịt kho" khỏi danh sách ứng viên

    active_other_indices = [idx for idx in OTHER_INDICES if idx != idx_loai_bo]

# ── Heuristic: đếm số miếng để chỉnh lại xác suất Sườn nướng vs Thịt kho ──
    # 1 miếng to -> tăng khả năng Sườn nướng, giảm Thịt kho
    # nhiều miếng nhỏ -> tăng khả năng Thịt kho, giảm Sườn nướng
    for ten_o in small_cells:
        so_mieng = dem_so_mieng_thit(cell_crops_food[ten_o])
        probs = cell_probs[ten_o]
        if so_mieng <= 1:
            probs[idx_suon_nuong] *= 4.0
            probs[idx_thit_kho]   *= 0.3
        elif so_mieng >= 3:
            probs[idx_thit_kho]   *= 1.5
            probs[idx_suon_nuong] *= 0.5
        print(f"    🔍 {ten_o}: đếm được {so_mieng} miếng -> "
              f"sườn nướng={probs[idx_suon_nuong]:.3f}, thịt kho={probs[idx_thit_kho]:.3f}")

    # ── 3 ô nhỏ: gán không trùng nhau, không phải cơm/canh, không vi phạm ràng buộc trên ──
    prob_matrix = np.array([
        [cell_probs[c][idx] for idx in active_other_indices]
        for c in small_cells
    ])
    row_idx, col_idx = linear_sum_assignment(-prob_matrix)

    for r, c in zip(row_idx, col_idx):
        ten_o     = small_cells[r]
        class_idx = active_other_indices[c]
        ket_qua_5_o[ten_o] = (
            idx_to_class[class_idx],
            float(prob_matrix[r, c])
        )
 
# ── DEBUG: in top-3 khả năng của mỗi ô để chẩn đoán ──
    print("\n  📊 Top-3 khả năng mỗi ô:")
    for ten_o in all_cells:
        probs = cell_probs[ten_o]
        top3 = sorted(enumerate(probs), key=lambda x: -x[1])[:3]
        ten_top3 = [(idx_to_class[i], round(p, 3)) for i, p in top3]
        print(f"    {ten_o}: {ten_top3}")
    return ket_qua_5_o


