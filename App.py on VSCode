}
PAD = 0.012
WARP_W, WARP_H = 1600, 1200


def order_points(pts):
    pts = pts[np.argsort(pts[:, 1])]
    top = pts[:2][np.argsort(pts[:2, 0])]
    bottom = pts[2:][np.argsort(pts[2:, 0])]
    return np.array([top[0], top[1], bottom[1], bottom[0]], dtype="float32")


def find_tray_corners_auto(img):
    """Tự dò khay bằng contour (dùng khi chưa calibrate corners.json)."""
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    blur = cv2.GaussianBlur(gray, (5, 5), 0)
    _, thresh = cv2.threshold(blur, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)
    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if not contours:
        raise ValueError("Không tìm thấy khay trong khung hình")
    c = max(contours, key=cv2.contourArea)
    area_ratio = cv2.contourArea(c) / (img.shape[0] * img.shape[1])
    if area_ratio < 0.15:
        raise ValueError("Khay quá nhỏ / không nằm trong khung hình")
    rect = cv2.minAreaRect(c)
    box = cv2.boxPoints(rect)
    return order_points(box)


# Nếu đã chạy calibrate.py thì dùng tọa độ cố định (nhanh + ổn định hơn)
